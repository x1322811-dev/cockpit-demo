{
  "name": "cockpit-agent-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "test": "tsx --test deploy.test.ts",
    "typecheck": "tsc --noEmit",
    "eval": "tsx --env-file=.env eval/run.ts",
    "eval:diff": "tsx eval/diff.ts"
  },
  "dependencies": {
    "openai": "^4.77.0",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.0"
  }
}
